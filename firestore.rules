rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function authUid() {
      return request.auth.uid;
    }
    
    function isOwnerOf(userId) {
      return isSignedIn() && authUid() == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isRep() {
      return isAdmin() || (isSignedIn() && request.auth.token.role == 'rep');
    }

    function isOwner() {
      return isAdmin() || (isSignedIn() && request.auth.token.role == 'owner');
    }

    // --- 1. User Profiles ---
    match /users/{userId} {
      allow read, write: if isOwnerOf(userId) || isAdmin();
      allow read: if isRep();
    }

    // --- 2. Stores ---
    match /stores/{storeId} {
      // REQUIRE authentication for get to comply with professional security standards.
      // NOTE: For best security, sensitive data like "owner_api_key" should be stored in 
      // a separate, restrictive subcollection (e.g. stores/{storeId}/private/config) 
      // where read is restricted to Admin/Owner only.
      allow get: if isSignedIn(); 
      allow list: if isSignedIn();
      allow create: if isRep();
      allow update, delete: if isAdmin() || 
                    (isRep() && resource.data.repId == authUid()) || 
                    (isOwner() && resource.data.ownerId == authUid());

      match /inventory/{wineId} {
        allow read: if true;
        allow write: if isAdmin() || 
                      (isRep() && get(/databases/$(database)/documents/stores/$(storeId)).data.repId == authUid()) || 
                      (isOwner() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == authUid());
      }
    }

    // --- 3. Master Data ---
    match /winesMaster/{wineId} {
      allow read: if isSignedIn();
      allow write: if isRep();
    }
    
    // --- 4. Diagnostic ---
    match /test/connection {
      allow read: if true;
    }
  }
}
