rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function authUid() { return request.auth.uid; }
    function isOwnerOf(userId) { return isSignedIn() && authUid() == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.role == 'admin'; }
    function isRep() { return isAdmin() || (isSignedIn() && request.auth.token.role == 'rep'); }
    function isOwner() { return isAdmin() || (isSignedIn() && request.auth.token.role == 'owner'); }

    // --- 1. User Profiles ---
    match /users/{userId} {
      allow read: if isOwnerOf(userId) || isAdmin() || isRep();
      allow create: if isOwnerOf(userId) || isAdmin();
      // 【セキュリティ強化】特権昇格を防ぐため、ユーザー自身は role, storeId, repId, uid などの重要フィールドを変更できないよう制限
      allow update: if isAdmin() || (isOwnerOf(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'storeId', 'repId', 'uid']));
      allow delete: if isAdmin();
    }

    // --- 2. Stores ---
    match /stores/{storeId} {
      allow get: if isSignedIn(); 
      allow list: if isSignedIn();
      allow create: if isRep();
      allow update: if isAdmin() ||
        (isSignedIn() && (
          (request.auth.token.role == 'rep' && resource.data.repId == authUid()) || 
          (request.auth.token.role == 'owner' && (request.auth.token.storeId == storeId || resource.data.ownerId == authUid()))
        ));
      // 【バグ修正】オーナーによる誤操作・悪意ある店舗削除を防止。削除はAdminと担当営業（Rep）のみ可能に。
      allow delete: if isAdmin() || (isSignedIn() && request.auth.token.role == 'rep' && resource.data.repId == authUid());

      match /inventory/{wineId} {
        allow read: if true;
        allow write: if isAdmin() ||
        (isSignedIn() && (
          (request.auth.token.role == 'owner' && request.auth.token.storeId == storeId) ||
          (request.auth.token.role == 'rep' && get(/databases/$(database)/documents/stores/$(storeId)).data.repId == authUid())
        ));
      }
    }

    // --- 3. Master Data ---
    match /winesMaster/{wineId} {
      allow read: if isSignedIn();
      allow write: if isRep();
    }
    
    // --- 4. Diagnostic ---
    match /test/connection {
      allow read: if true;
    }
  }
}
