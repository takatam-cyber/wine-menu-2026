rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function authUid() {
      return request.auth.uid;
    }
    
    function isOwnerOf(userId) {
      return isSignedIn() && authUid() == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' || 
        request.auth.token.email.matches('.*@pieroth\\.jp$') || 
        request.auth.token.email == 'takatam40725@gmail.com'
      );
    }

    function isRep() {
      return isAdmin() || (isSignedIn() && request.auth.token.role == 'rep');
    }

    function isOwner() {
      return isAdmin() || (isSignedIn() && request.auth.token.role == 'owner');
    }

    // --- 1. User Profiles ---
    match /users/{userId} {
      allow read, write: if isOwnerOf(userId) || isAdmin();
      allow read: if isRep();
    }

    // --- 2. Stores ---
    match /stores/{storeId} {
      // Helpers for relational access
      function storeData() {
        return get(/databases/$(database)/documents/stores/$(storeId)).data;
      }
      
      function canManageStore() {
        let data = storeData();
        return isAdmin() || 
               (isRep() && data.repId == authUid()) || 
               (isOwner() && data.ownerId == authUid());
      }

      // REQUIRE authentication for get.
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isRep();
      allow update, delete: if canManageStore();

      match /inventory/{wineId} {
        // Restrict read to authorized personnel only. 
        // Customers fetch via server-side API which bypasses this.
        allow read, write: if canManageStore();
      }
    }

    // --- 3. Master Data ---
    match /winesMaster/{wineId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // --- 4. Diagnostic ---
    match /test/connection {
      allow read: if true;
    }
  }
}
