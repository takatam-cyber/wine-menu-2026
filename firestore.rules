rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 0. Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function authUid() {
      return request.auth.uid;
    }
    
    function isOwnerOf(userId) {
      return isSignedIn() && authUid() == userId;
    }

    // 暫定的な管理者定義（デプロイ成功までを確実にするため）
    function isAdmin() {
      return isVerified() && (
        request.auth.token.role == 'admin' || 
        request.auth.token.email == 'takatam@pieroth.jp' || 
        request.auth.token.email == 'takatam40725@gmail.com'
      );
    }

    function isRep() {
      return isAdmin() || (isVerified() && request.auth.token.role == 'rep');
    }

    function isOwner() {
      return isAdmin() || (isVerified() && request.auth.token.role == 'owner');
    }

    // --- 1. User Profiles ---
    match /users/{userId} {
      // 自分のプロフィールは常に全アクセスを許可
      allow read, write: if isOwnerOf(userId);
      
      // 管理者と営業マンは全ユーザーを取得可能
      allow read: if isAdmin() || isRep();
    }

    // --- 2. Stores ---
    match /stores/{storeId} {
      allow get: if true; 
      allow list: if isSignedIn();
      
      allow create: if isRep();
      allow update: if isAdmin() || 
                    (isRep() && resource.data.repId == authUid()) || 
                    (isOwner() && resource.data.ownerId == authUid());

      match /inventory/{wineId} {
        allow read: if true;
        allow write: if isAdmin() || 
                      (isRep() && get(/databases/$(database)/documents/stores/$(storeId)).data.repId == authUid()) ||
                      (isOwner() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == authUid());
      }
    }

    // --- 3. Master Data ---
    match /winesMaster/{wineId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
